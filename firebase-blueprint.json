{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "wishlist": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "name", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "rating": { "type": "number" },
        "stock": { "type": "integer" },
        "isOrganic": { "type": "boolean" },
        "isGlutenFree": { "type": "boolean" },
        "isVegan": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "images", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "userName", "rating", "comment", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Home screen banners",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "image", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Order information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trackingNumber": { "type": "string" },
        "estimatedDelivery": { "type": "string", "format": "date-time" },
        "trackingStatus": { "type": "string", "enum": ["Packed", "Shipped", "Delivered"] },
        "discount": { "type": "number" },
        "couponCode": { "type": "string" }
      },
      "required": ["userId", "total", "status", "address", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minPurchase": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discountType", "discountValue", "expiryDate", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Banners"
    },
    "/orders/{userId}/userOrders/{orderId}": {
      "schema": "Order",
      "description": "User specific orders"
    },
    "/all_orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders for admin"
    },
    "/cart/{userId}": {
      "schema": "object",
      "description": "User shopping cart"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons"
    }
  }
}
